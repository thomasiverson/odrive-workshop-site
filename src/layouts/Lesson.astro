---
import Base from './Base.astro';

interface Props {
  title: string;
  order: number;
  type: string;
  duration?: string;
  prevLesson?: { slug: string; title: string } | null;
  nextLesson?: { slug: string; title: string } | null;
  exercisesSlug?: string | null;
}

const { title, order, type, duration, prevLesson, nextLesson, exercisesSlug } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<Base title={`${title} — ODrive Workshop`}>
  <div class="lesson-page">
    <aside class="lesson-meta">
      <a href={base} class="back-link">&larr; All Lessons</a>
      <div class="lesson-badge">Lesson {order}</div>
      {duration && <div class="duration-badge">{duration}</div>}
      {type === 'lesson' && exercisesSlug && (
        <a href={`${base}lessons/${exercisesSlug}/`} class="exercises-link">
          🧪 Hands-On Exercises
        </a>
      )}
      {type === 'exercises' && (
        <div class="type-badge exercises">Hands-On Exercises</div>
      )}
    </aside>

    <article class="content">
      <slot />
    </article>

    <nav class="lesson-nav">
      {prevLesson ? (
        <a href={`${base}lessons/${prevLesson.slug}/`} class="nav-prev">
          &larr; {prevLesson.title}
        </a>
      ) : <span />}
      {nextLesson ? (
        <a href={`${base}lessons/${nextLesson.slug}/`} class="nav-next">
          {nextLesson.title} &rarr;
        </a>
      ) : <span />}
    </nav>
  </div>
</Base>

<style>
  .lesson-page {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .lesson-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .back-link {
    color: var(--text-muted);
    font-size: 0.9rem;
    text-decoration: none;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .lesson-badge {
    background: var(--accent-emphasis);
    color: white;
    padding: 0.2rem 0.6rem;
    border-radius: 12px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .duration-badge {
    background: var(--bg-surface);
    color: var(--text-muted);
    padding: 0.2rem 0.6rem;
    border-radius: 12px;
    font-size: 0.8rem;
    border: 1px solid var(--border);
  }

  .type-badge.exercises {
    background: #1a3a2a;
    color: var(--green);
    padding: 0.2rem 0.6rem;
    border-radius: 12px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .exercises-link {
    background: #1a3a2a;
    color: var(--green);
    padding: 0.2rem 0.6rem;
    border-radius: 12px;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s;
  }

  .exercises-link:hover {
    background: #1f4a33;
    text-decoration: none;
  }

  .lesson-nav {
    display: flex;
    justify-content: space-between;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .nav-prev, .nav-next {
    color: var(--accent);
    text-decoration: none;
    font-size: 0.95rem;
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    transition: background 0.15s;
  }

  .nav-prev:hover, .nav-next:hover {
    background: var(--bg-surface);
    text-decoration: none;
  }

  .nav-next {
    margin-left: auto;
  }
</style>
